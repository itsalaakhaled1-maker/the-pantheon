<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Pantheon — مجلس الاستثمار الذكي</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Cairo:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,700;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --gold: #C9A84C;
  --gold-light: #E8C97A;
  --gold-dim: #7A6030;
  --obsidian: #080A0E;
  --obsidian-2: #0D1018;
  --obsidian-3: #141820;
  --obsidian-4: #1C2230;
  --stone: #2A3040;
  --text: #D4C5A0;
  --text-dim: #7A7060;
  --white: #F5EED8;
  --green: #2ECC71;
  --red: #E74C3C;
  --amber: #F39C12;
  --blue: #3498DB;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  font-family: 'Cairo', sans-serif;
  background: var(--obsidian);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ─── BACKGROUND ─── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 50% -10%, rgba(201,168,76,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 90% 90%, rgba(201,168,76,0.04) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* ─── GRAIN OVERLAY ─── */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
  opacity: 0.3;
  pointer-events: none;
  z-index: 0;
}

.container { position: relative; z-index: 1; max-width: 1100px; margin: 0 auto; padding: 0 24px; }

/* ─── HEADER ─── */
header {
  border-bottom: 1px solid rgba(201,168,76,0.15);
  padding: 32px 0 28px;
  margin-bottom: 56px;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo-block { display: flex; align-items: center; gap: 16px; }

.logo-emblem {
  width: 52px;
  height: 52px;
  border: 1.5px solid var(--gold-dim);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Cinzel', serif;
  font-size: 22px;
  color: var(--gold);
  background: radial-gradient(circle, rgba(201,168,76,0.1) 0%, transparent 70%);
  letter-spacing: 1px;
}

.logo-text h1 {
  font-family: 'Cinzel', serif;
  font-size: 22px;
  font-weight: 700;
  color: var(--gold);
  letter-spacing: 4px;
  text-transform: uppercase;
}

.logo-text p {
  font-size: 11px;
  color: var(--text-dim);
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-top: 2px;
}

.header-badge {
  font-size: 11px;
  color: var(--text-dim);
  letter-spacing: 2px;
  text-transform: uppercase;
  border: 1px solid rgba(201,168,76,0.15);
  padding: 6px 14px;
  border-radius: 2px;
}

/* ─── HERO ─── */
.hero {
  text-align: center;
  margin-bottom: 64px;
}

.hero-tag {
  display: inline-block;
  font-size: 11px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold-dim);
  border-top: 1px solid var(--gold-dim);
  border-bottom: 1px solid var(--gold-dim);
  padding: 6px 20px;
  margin-bottom: 28px;
}

.hero h2 {
  font-family: 'Cinzel', serif;
  font-size: clamp(28px, 5vw, 52px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
  margin-bottom: 16px;
}

.hero h2 span { color: var(--gold); }

.hero p {
  font-size: 16px;
  color: var(--text-dim);
  max-width: 520px;
  margin: 0 auto 40px;
  line-height: 1.8;
}

/* ─── SEARCH ─── */
.search-box {
  max-width: 600px;
  margin: 0 auto;
  position: relative;
}

.search-row {
  display: flex;
  gap: 0;
  border: 1px solid rgba(201,168,76,0.3);
  background: var(--obsidian-2);
  border-radius: 3px;
  overflow: hidden;
  transition: border-color 0.3s;
}

.search-row:focus-within { border-color: var(--gold); }

.search-row input {
  flex: 1;
  background: transparent;
  border: none;
  outline: none;
  padding: 18px 24px;
  font-family: 'Cairo', sans-serif;
  font-size: 16px;
  color: var(--white);
  direction: rtl;
}

.search-row input::placeholder { color: var(--text-dim); }

.search-btn {
  background: var(--gold);
  border: none;
  padding: 18px 28px;
  cursor: pointer;
  font-family: 'Cinzel', serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--obsidian);
  letter-spacing: 2px;
  text-transform: uppercase;
  transition: background 0.2s;
  white-space: nowrap;
}

.search-btn:hover { background: var(--gold-light); }
.search-btn:disabled { background: var(--gold-dim); cursor: not-allowed; }

.suggestions {
  display: flex;
  gap: 8px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 16px;
}

.sug-chip {
  font-size: 12px;
  color: var(--text-dim);
  border: 1px solid rgba(201,168,76,0.15);
  padding: 5px 14px;
  border-radius: 2px;
  cursor: pointer;
  transition: all 0.2s;
}

.sug-chip:hover { border-color: var(--gold); color: var(--gold); }

/* ─── PROGRESS ─── */
#progress-section {
  display: none;
  margin-bottom: 48px;
  background: var(--obsidian-2);
  border: 1px solid rgba(201,168,76,0.15);
  border-radius: 4px;
  padding: 32px;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.progress-header h3 {
  font-family: 'Cinzel', serif;
  font-size: 14px;
  color: var(--gold);
  letter-spacing: 3px;
}

.progress-pct { font-size: 13px; color: var(--text-dim); font-variant-numeric: tabular-nums; }

.progress-bar-track {
  height: 2px;
  background: var(--stone);
  border-radius: 1px;
  margin-bottom: 16px;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--gold-dim), var(--gold));
  border-radius: 1px;
  transition: width 0.5s ease;
  width: 0%;
}

.progress-msg {
  font-size: 14px;
  color: var(--text-dim);
  min-height: 20px;
}

.live-agents { margin-top: 20px; display: flex; flex-wrap: wrap; gap: 8px; }

.agent-chip {
  font-size: 12px;
  padding: 5px 12px;
  border-radius: 2px;
  border: 1px solid rgba(201,168,76,0.15);
  color: var(--text-dim);
  animation: fadeIn 0.4s ease;
  display: flex; align-items: center; gap: 6px;
}

.agent-chip.buy { border-color: rgba(46,204,113,0.3); color: var(--green); }
.agent-chip.sell { border-color: rgba(231,76,60,0.3); color: var(--red); }
.agent-chip.hold { border-color: rgba(243,156,18,0.3); color: var(--amber); }

/* ─── RESULTS ─── */
#results-section { display: none; }

/* VERDICT CARD */
.verdict-card {
  border: 1px solid rgba(201,168,76,0.3);
  background: linear-gradient(135deg, var(--obsidian-2) 0%, var(--obsidian-3) 100%);
  border-radius: 4px;
  padding: 40px;
  margin-bottom: 32px;
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.6s ease;
}

.verdict-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

.verdict-grid {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 32px;
  align-items: center;
}

.verdict-label {
  font-family: 'Cinzel', serif;
  font-size: 11px;
  letter-spacing: 3px;
  color: var(--text-dim);
  text-transform: uppercase;
  margin-bottom: 8px;
}

.verdict-big {
  font-family: 'Cinzel', serif;
  font-size: 52px;
  font-weight: 900;
  line-height: 1;
}

.verdict-big.BUY { color: var(--green); }
.verdict-big.SELL { color: var(--red); }
.verdict-big.HOLD { color: var(--amber); }

.conviction-badge {
  display: inline-block;
  font-size: 11px;
  letter-spacing: 2px;
  padding: 4px 12px;
  border-radius: 2px;
  margin-top: 10px;
}

.conviction-badge.HIGH { background: rgba(46,204,113,0.1); color: var(--green); border: 1px solid rgba(46,204,113,0.3); }
.conviction-badge.MEDIUM { background: rgba(243,156,18,0.1); color: var(--amber); border: 1px solid rgba(243,156,18,0.3); }
.conviction-badge.LOW { background: rgba(231,76,60,0.1); color: var(--red); border: 1px solid rgba(231,76,60,0.3); }

.allocation-bars { display: flex; flex-direction: column; gap: 10px; }

.alloc-row { display: flex; align-items: center; gap: 12px; }

.alloc-label { font-size: 12px; color: var(--text-dim); width: 50px; text-align: right; }

.alloc-track { flex: 1; height: 6px; background: var(--stone); border-radius: 3px; overflow: hidden; }

.alloc-fill { height: 100%; border-radius: 3px; transition: width 1s ease 0.5s; width: 0%; }
.alloc-fill.buy { background: var(--green); }
.alloc-fill.hold { background: var(--amber); }
.alloc-fill.sell { background: var(--red); }

.alloc-pct { font-size: 13px; color: var(--white); width: 36px; font-variant-numeric: tabular-nums; }

.verdict-summary {
  font-size: 15px;
  color: var(--text);
  line-height: 1.9;
  margin-top: 24px;
  padding-top: 24px;
  border-top: 1px solid rgba(201,168,76,0.1);
}

/* CASES GRID */
.cases-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-top: 24px;
}

.case-card {
  background: var(--obsidian-3);
  border-radius: 3px;
  padding: 20px;
  border-right: 3px solid transparent;
}

.case-card.bull { border-right-color: var(--green); }
.case-card.bear { border-right-color: var(--red); }

.case-label {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 8px;
}

.case-card.bull .case-label { color: var(--green); }
.case-card.bear .case-label { color: var(--red); }

.case-text { font-size: 14px; color: var(--text-dim); line-height: 1.7; }

/* SECTION TITLE */
.section-title {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  letter-spacing: 4px;
  color: var(--gold);
  text-transform: uppercase;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.section-title::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(201,168,76,0.15);
}

/* AGENTS GRID */
.agents-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 16px;
  margin-bottom: 32px;
  animation: fadeUp 0.6s ease 0.2s both;
}

.agent-card {
  background: var(--obsidian-2);
  border: 1px solid rgba(201,168,76,0.1);
  border-radius: 4px;
  padding: 24px;
  transition: border-color 0.2s;
}

.agent-card:hover { border-color: rgba(201,168,76,0.3); }

.agent-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14px;
}

.agent-name-block {}

.agent-emoji { font-size: 22px; margin-bottom: 4px; display: block; }
.agent-name { font-family: 'Cinzel', serif; font-size: 13px; color: var(--white); letter-spacing: 1px; }

.verdict-pill {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  padding: 5px 12px;
  border-radius: 2px;
}

.verdict-pill.BUY { background: rgba(46,204,113,0.15); color: var(--green); }
.verdict-pill.SELL { background: rgba(231,76,60,0.15); color: var(--red); }
.verdict-pill.HOLD { background: rgba(243,156,18,0.15); color: var(--amber); }

.agent-confidence {
  font-size: 12px;
  color: var(--text-dim);
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.conf-bar { flex: 1; height: 3px; background: var(--stone); border-radius: 2px; overflow: hidden; }
.conf-fill { height: 100%; background: var(--gold); border-radius: 2px; }

.agent-reasoning { font-size: 13px; color: var(--text-dim); line-height: 1.7; margin-bottom: 14px; }

.agent-risks {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  border-top: 1px solid rgba(201,168,76,0.08);
  padding-top: 14px;
}

.risk-block label { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--text-dim); display: block; margin-bottom: 4px; }
.risk-block span { font-size: 12px; color: var(--text); }

/* CROWD SECTION */
.crowd-section {
  margin-bottom: 32px;
  animation: fadeUp 0.6s ease 0.3s both;
}

.crowd-summary {
  background: var(--obsidian-2);
  border: 1px solid rgba(201,168,76,0.1);
  border-radius: 4px;
  padding: 28px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 32px;
}

.crowd-big {
  font-family: 'Cinzel', serif;
  font-size: 13px;
  color: var(--text-dim);
  letter-spacing: 2px;
  text-align: center;
}

.crowd-big span {
  display: block;
  font-size: 38px;
  font-weight: 700;
  color: var(--white);
  font-variant-numeric: tabular-nums;
}

.crowd-big.g span { color: var(--green); }
.crowd-big.r span { color: var(--red); }
.crowd-big.a span { color: var(--amber); }

.crowd-divider { width: 1px; height: 60px; background: rgba(201,168,76,0.1); }

.crowd-text { flex: 1; font-size: 14px; color: var(--text-dim); line-height: 1.7; }

.crowd-batches {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 10px;
}

.batch-card {
  background: var(--obsidian-3);
  border: 1px solid rgba(201,168,76,0.08);
  border-radius: 3px;
  padding: 14px 16px;
}

.batch-name { font-size: 11px; color: var(--text-dim); margin-bottom: 8px; }

.batch-bar-row { display: flex; height: 4px; border-radius: 2px; overflow: hidden; gap: 1px; margin-bottom: 8px; }
.batch-bar-buy { background: var(--green); }
.batch-bar-hold { background: var(--amber); }
.batch-bar-sell { background: var(--red); }

.batch-emotion { font-size: 12px; color: var(--text); }

/* STRATEGY SECTION */
.strategy-section {
  background: var(--obsidian-2);
  border: 1px solid rgba(201,168,76,0.15);
  border-radius: 4px;
  padding: 32px;
  margin-bottom: 32px;
  animation: fadeUp 0.6s ease 0.4s both;
}

.strategy-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

.strategy-item label {
  font-size: 11px;
  letter-spacing: 2px;
  color: var(--gold-dim);
  text-transform: uppercase;
  display: block;
  margin-bottom: 8px;
}

.strategy-item p { font-size: 14px; color: var(--text); line-height: 1.7; }

.metrics-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.metric-tag {
  font-size: 13px;
  color: var(--text-dim);
  padding: 6px 0;
  border-bottom: 1px solid rgba(201,168,76,0.06);
  display: flex;
  align-items: center;
  gap: 8px;
}

.metric-tag::before { content: '◆'; font-size: 8px; color: var(--gold-dim); }

.risk-badge {
  display: inline-block;
  font-size: 12px;
  letter-spacing: 2px;
  padding: 6px 16px;
  border-radius: 2px;
}

.risk-badge.LOW { background: rgba(46,204,113,0.1); color: var(--green); }
.risk-badge.MEDIUM { background: rgba(243,156,18,0.1); color: var(--amber); }
.risk-badge.HIGH { background: rgba(231,76,60,0.1); color: var(--red); }
.risk-badge.EXTREME { background: rgba(231,76,60,0.2); color: #FF6B6B; }

/* NEWS */
.news-section {
  margin-bottom: 48px;
  animation: fadeUp 0.6s ease 0.5s both;
}

.news-list { display: flex; flex-direction: column; gap: 10px; }

.news-item {
  background: var(--obsidian-2);
  border: 1px solid rgba(201,168,76,0.08);
  border-radius: 3px;
  padding: 16px 20px;
  display: flex;
  gap: 16px;
  align-items: flex-start;
  transition: border-color 0.2s;
}

.news-item:hover { border-color: rgba(201,168,76,0.2); }

.news-index { font-family: 'Cinzel', serif; font-size: 18px; color: var(--gold-dim); min-width: 28px; }

.news-content { flex: 1; }
.news-title { font-size: 14px; color: var(--white); margin-bottom: 6px; line-height: 1.5; }
.news-snippet { font-size: 12px; color: var(--text-dim); line-height: 1.6; }

.news-link {
  font-size: 11px;
  color: var(--gold-dim);
  text-decoration: none;
  letter-spacing: 1px;
  white-space: nowrap;
  margin-top: 2px;
  display: block;
}

.news-link:hover { color: var(--gold); }

/* FOOTER */
footer {
  border-top: 1px solid rgba(201,168,76,0.1);
  padding: 32px 0;
  text-align: center;
  color: var(--text-dim);
  font-size: 12px;
  letter-spacing: 2px;
}

footer span { color: var(--gold-dim); }

/* ANIMATIONS */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* RESPONSIVE */
@media (max-width: 640px) {
  .verdict-grid { grid-template-columns: 1fr; }
  .cases-grid { grid-template-columns: 1fr; }
  .strategy-grid { grid-template-columns: 1fr; }
  .agents-grid { grid-template-columns: 1fr; }
  .crowd-summary { flex-direction: column; gap: 16px; }
  .crowd-divider { width: 60px; height: 1px; }
  .header-badge { display: none; }
}
</style>
</head>
<body>

<div class="container">
  <header>
    <div class="header-inner">
      <div class="logo-block">
        <div class="logo-emblem">P</div>
        <div class="logo-text">
          <h1>The Pantheon</h1>
          <p>مجلس الاستثمار الذكي</p>
        </div>
      </div>
      <div class="header-badge">1000 AGENT COUNCIL</div>
    </div>
  </header>

  <!-- HERO -->
  <div class="hero">
    <div class="hero-tag">AI Investment Intelligence</div>
    <h2>قرار واحد يحتاج<br><span>ألف عقل</span></h2>
    <p>اكتب اسم أي سهم أو عملة أو صندوق، وسيقوم مجلس الـ 1000 خبير بتحليل السوق وإصدار الحكم.</p>

    <div class="search-box">
      <div class="search-row">
        <input type="text" id="assetInput" placeholder="مثال: NVIDIA، Bitcoin، ذهب، Tesla..." />
        <button class="search-btn" id="analyzeBtn" onclick="startAnalysis()">تحليل</button>
      </div>
      <div class="suggestions">
        <span class="sug-chip" onclick="setAsset('NVIDIA')">NVIDIA</span>
        <span class="sug-chip" onclick="setAsset('Bitcoin')">Bitcoin</span>
        <span class="sug-chip" onclick="setAsset('Tesla')">Tesla</span>
        <span class="sug-chip" onclick="setAsset('ذهب')">ذهب</span>
        <span class="sug-chip" onclick="setAsset('Saudi Aramco')">Saudi Aramco</span>
      </div>
    </div>
  </div>

  <!-- PROGRESS -->
  <div id="progress-section">
    <div class="progress-header">
      <h3>ANALYSIS IN PROGRESS</h3>
      <span class="progress-pct" id="progressPct">0%</span>
    </div>
    <div class="progress-bar-track">
      <div class="progress-bar-fill" id="progressBar"></div>
    </div>
    <div class="progress-msg" id="progressMsg">جارٍ التحضير...</div>
    <div class="live-agents" id="liveAgents"></div>
  </div>

  <!-- RESULTS -->
  <div id="results-section">

    <!-- VERDICT -->
    <div class="section-title">الحكم النهائي</div>
    <div class="verdict-card" id="verdictCard">
      <div class="verdict-grid">
        <div>
          <div class="verdict-label">قرار المجلس</div>
          <div class="verdict-big" id="verdictText">—</div>
          <div class="conviction-badge" id="convictionBadge">—</div>
        </div>
        <div>
          <div class="verdict-label" style="margin-bottom:14px;">توزيع التوصية</div>
          <div class="allocation-bars">
            <div class="alloc-row">
              <span class="alloc-label">شراء</span>
              <div class="alloc-track"><div class="alloc-fill buy" id="allocBuy"></div></div>
              <span class="alloc-pct" id="allocBuyPct">0%</span>
            </div>
            <div class="alloc-row">
              <span class="alloc-label">احتفاظ</span>
              <div class="alloc-track"><div class="alloc-fill hold" id="allocHold"></div></div>
              <span class="alloc-pct" id="allocHoldPct">0%</span>
            </div>
            <div class="alloc-row">
              <span class="alloc-label">بيع</span>
              <div class="alloc-track"><div class="alloc-fill sell" id="allocSell"></div></div>
              <span class="alloc-pct" id="allocSellPct">0%</span>
            </div>
          </div>
        </div>
        <div style="text-align:center;">
          <div class="verdict-label" style="margin-bottom:8px;">مستوى المخاطرة</div>
          <div id="riskBadge" class="risk-badge">—</div>
          <div style="margin-top:16px;">
            <div class="verdict-label">الأفق الزمني</div>
            <div style="font-family:'Cinzel',serif; font-size:14px; color:var(--white); margin-top:4px;" id="timeHorizon">—</div>
          </div>
        </div>
      </div>
      <div class="verdict-summary" id="verdictSummary"></div>
      <div class="cases-grid">
        <div class="case-card bull">
          <div class="case-label">🟢 السيناريو الإيجابي</div>
          <div class="case-text" id="bullCase"></div>
        </div>
        <div class="case-card bear">
          <div class="case-label">🔴 السيناريو السلبي</div>
          <div class="case-text" id="bearCase"></div>
        </div>
      </div>
    </div>

    <!-- STAR AGENTS -->
    <div class="section-title">آراء خبراء المجلس العشرة</div>
    <div class="agents-grid" id="agentsGrid"></div>

    <!-- CROWD -->
    <div class="crowd-section">
      <div class="section-title">نبض الـ 990 مستثمر</div>
      <div class="crowd-summary" id="crowdSummary">
        <div class="crowd-big g"><span id="crowdBuy">—</span>شراء</div>
        <div class="crowd-divider"></div>
        <div class="crowd-big a"><span id="crowdHold">—</span>احتفاظ</div>
        <div class="crowd-divider"></div>
        <div class="crowd-big r"><span id="crowdSell">—</span>بيع</div>
        <div class="crowd-divider"></div>
        <div class="crowd-text" id="crowdText"></div>
      </div>
      <div class="crowd-batches" id="crowdBatches"></div>
    </div>

    <!-- STRATEGY -->
    <div class="strategy-section">
      <div class="section-title">استراتيجية الدخول والمتابعة</div>
      <div class="strategy-grid">
        <div class="strategy-item">
          <label>خطة الدخول</label>
          <p id="entryStrategy"></p>
        </div>
        <div class="strategy-item">
          <label>المؤشرات الواجب مراقبتها</label>
          <div class="metrics-list" id="metricsList"></div>
        </div>
      </div>
    </div>

    <!-- NEWS -->
    <div class="news-section">
      <div class="section-title">أحدث الأخبار المؤثرة</div>
      <div class="news-list" id="newsList"></div>
    </div>

  </div>

  <footer>
    <p>The Pantheon — <span>ليس نصيحة استثمارية</span> — للأغراض التعليمية والتحليلية فقط</p>
  </footer>
</div>

<script>
function setAsset(name) {
  document.getElementById('assetInput').value = name;
}

const BATCH_NAMES = {
  retail_fearful: 'مستثمرون مبتدئون خائفون',
  retail_greedy: 'مستثمرون متحمسون',
  institutional_small: 'مديرو صناديق صغيرة',
  crypto_traders: 'متداولو العملات الرقمية',
  conservative_savers: 'مدخرون محافظون',
  emerging_market: 'مستثمرون من الأسواق الناشئة',
  quant_traders: 'متداولون كميون',
  esg_investors: 'مستثمرو ESG',
  day_traders: 'متداولو اليوم',
  value_hunters: 'صائدو القيمة',
};

const VERDICTS_AR = { BUY: 'شراء', SELL: 'بيع', HOLD: 'احتفاظ' };
const CONVICTION_AR = { HIGH: 'ثقة عالية', MEDIUM: 'ثقة متوسطة', LOW: 'ثقة منخفضة' };
const RISK_AR = { LOW: 'مخاطرة منخفضة', MEDIUM: 'مخاطرة متوسطة', HIGH: 'مخاطرة عالية', EXTREME: 'مخاطرة شديدة' };
const HORIZON_AR = { SHORT: 'قصير المدى', MEDIUM: 'متوسط المدى', LONG: 'طويل المدى' };

async function startAnalysis() {
  const asset = document.getElementById('assetInput').value.trim();
  if (!asset) return;

  const btn = document.getElementById('analyzeBtn');
  btn.disabled = true;
  btn.textContent = 'جارٍ التحليل...';

  document.getElementById('progress-section').style.display = 'block';
  document.getElementById('results-section').style.display = 'none';
  document.getElementById('liveAgents').innerHTML = '';

  setProgress(0, 'جارٍ الاتصال...');

  try {
    const response = await fetch('/api/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ asset }),
    });

    const reader = response.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;

      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop();

      for (const line of lines) {
        if (line.startsWith('data: ')) {
          try {
            const data = JSON.parse(line.slice(6));
            handleEvent(data);
          } catch {}
        }
      }
    }
  } catch (err) {
    setProgress(0, '❌ خطأ: ' + err.message);
  }

  btn.disabled = false;
  btn.textContent = 'تحليل';
}

function setProgress(pct, msg) {
  document.getElementById('progressBar').style.width = pct + '%';
  document.getElementById('progressPct').textContent = pct + '%';
  document.getElementById('progressMsg').textContent = msg;
}

function handleEvent(data) {
  setProgress(data.progress || 0, data.message || '');

  if (data.step === 'agent_done' && data.agent) {
    const chip = document.createElement('div');
    chip.className = `agent-chip ${data.agent.verdict?.toLowerCase()}`;
    chip.textContent = `${data.agent.emoji} ${data.agent.agent}`;
    document.getElementById('liveAgents').appendChild(chip);
  }

  if (data.step === 'complete' && data.data) {
    renderResults(data.data);
  }
}

function renderResults(data) {
  document.getElementById('progress-section').style.display = 'none';
  document.getElementById('results-section').style.display = 'block';

  const v = data.verdict;

  // Verdict
  const verdictEl = document.getElementById('verdictText');
  verdictEl.textContent = VERDICTS_AR[v.overall_verdict] || v.overall_verdict;
  verdictEl.className = `verdict-big ${v.overall_verdict}`;

  const convBadge = document.getElementById('convictionBadge');
  convBadge.textContent = CONVICTION_AR[v.conviction] || v.conviction;
  convBadge.className = `conviction-badge ${v.conviction}`;

  // Allocations
  setTimeout(() => {
    document.getElementById('allocBuy').style.width = v.buy_allocation + '%';
    document.getElementById('allocHold').style.width = v.hold_allocation + '%';
    document.getElementById('allocSell').style.width = v.sell_allocation + '%';
  }, 100);
  document.getElementById('allocBuyPct').textContent = v.buy_allocation + '%';
  document.getElementById('allocHoldPct').textContent = v.hold_allocation + '%';
  document.getElementById('allocSellPct').textContent = v.sell_allocation + '%';

  // Risk & horizon
  const riskBadge = document.getElementById('riskBadge');
  riskBadge.textContent = RISK_AR[v.risk_level] || v.risk_level;
  riskBadge.className = `risk-badge ${v.risk_level}`;
  document.getElementById('timeHorizon').textContent = HORIZON_AR[v.time_horizon] || v.time_horizon;

  document.getElementById('verdictSummary').textContent = v.executive_summary;
  document.getElementById('bullCase').textContent = v.bull_case;
  document.getElementById('bearCase').textContent = v.bear_case;

  // Star Agents
  const grid = document.getElementById('agentsGrid');
  grid.innerHTML = data.starAgents.map(a => `
    <div class="agent-card">
      <div class="agent-header">
        <div class="agent-name-block">
          <span class="agent-emoji">${a.emoji}</span>
          <span class="agent-name">${a.agent}</span>
        </div>
        <span class="verdict-pill ${a.verdict}">${VERDICTS_AR[a.verdict] || a.verdict}</span>
      </div>
      <div class="agent-confidence">
        <span>ثقة ${a.confidence}%</span>
        <div class="conf-bar"><div class="conf-fill" style="width:${a.confidence}%"></div></div>
      </div>
      <div class="agent-reasoning">${a.reasoning}</div>
      <div class="agent-risks">
        <div class="risk-block"><label>أبرز خطر</label><span>${a.key_risk}</span></div>
        <div class="risk-block"><label>أبرز فرصة</label><span>${a.key_opportunity}</span></div>
      </div>
    </div>
  `).join('');

  // Crowd
  const crowd = data.crowd;
  const avgBuy = Math.round(crowd.reduce((s, c) => s + c.buy_percent, 0) / crowd.length);
  const avgSell = Math.round(crowd.reduce((s, c) => s + c.sell_percent, 0) / crowd.length);
  const avgHold = 100 - avgBuy - avgSell;

  document.getElementById('crowdBuy').textContent = avgBuy + '%';
  document.getElementById('crowdHold').textContent = avgHold + '%';
  document.getElementById('crowdSell').textContent = avgSell + '%';
  document.getElementById('crowdText').textContent = `من مجموع 990 مستثمراً يمثلون شرائح مختلفة من السوق العالمي، ${avgBuy > 50 ? 'الغالبية تميل للشراء' : avgSell > 50 ? 'الغالبية تميل للبيع' : 'الرأي منقسم بين المشاركين'}.`;

  document.getElementById('crowdBatches').innerHTML = crowd.map(c => `
    <div class="batch-card">
      <div class="batch-name">${BATCH_NAMES[c.batch] || c.batch}</div>
      <div class="batch-bar-row">
        <div class="batch-bar-buy" style="width:${c.buy_percent}%"></div>
        <div class="batch-bar-hold" style="width:${c.hold_percent}%"></div>
        <div class="batch-bar-sell" style="width:${c.sell_percent}%"></div>
      </div>
      <div class="batch-emotion">المشاعر السائدة: ${c.dominant_emotion}</div>
    </div>
  `).join('');

  // Strategy
  document.getElementById('entryStrategy').textContent = v.entry_strategy;
  document.getElementById('metricsList').innerHTML = (v.key_metrics_to_watch || []).map(m => `
    <div class="metric-tag">${m}</div>
  `).join('');

  // News
  document.getElementById('newsList').innerHTML = (data.news || []).map((n, i) => `
    <div class="news-item">
      <div class="news-index">0${i + 1}</div>
      <div class="news-content">
        <div class="news-title">${n.title}</div>
        <div class="news-snippet">${(n.content || '').substring(0, 120)}...</div>
        ${n.url ? `<a class="news-link" href="${n.url}" target="_blank">اقرأ المزيد →</a>` : ''}
      </div>
    </div>
  `).join('');

  window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.getElementById('assetInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') startAnalysis();
});
</script>
</body>
</html>
